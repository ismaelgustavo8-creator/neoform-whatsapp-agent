# NeoForm WhatsApp Agent - Environment Variables
# Copie este arquivo para .env e preencha com suas credenciais

# Supabase (PostgreSQL)
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_KEY=eyJ...sua-service-role-key

# Claude API (Anthropic)
ANTHROPIC_API_KEY=sk-ant-...sua-chave

# WhatsApp Cloud API (Meta)
WHATSAPP_TOKEN=seu-token-permanente
WHATSAPP_PHONE_ID=seu-phone-number-id
WHATSAPP_VERIFY_TOKEN=escolha-uma-senha-qualquer

# Mercado Pago (será configurado na Sprint 2)
# MERCADOPAGO_ACCESS_TOKEN=seu-access-token

# Melhor Envio (será configurado na Sprint 2)
# MELHOR_ENVIO_TOKEN=seu-token
# MELHOR_ENVIO_CEP_REMETENTE=01310100
